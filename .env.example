# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# ── Required ───────────────────────────────────────────────────────────────────
# Get your free Groq API key at https://console.groq.com
GROQ-API-KEY=your_groq_api_key_here

# ── Production only (set these as environment variables in Railway dashboard) ──
# Tell FastAPI to serve the built React frontend (set to "true" on Railway)
SERVE_FRONTEND=false

# Comma-separated list of allowed CORS origins for local dev.
# In production, leave this unset — same-origin requests don't need CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
